{
  "name": "opiumware-executor",
  "displayName": "Opiumware Icon",
  "description": "Run Lua scripts via Opiumware",
  "publisher": "SerhiiPok",
  "license": "MIT",
  "repository": "https://github.com/CoderSerg/opiumicon",
  "version": "0.1.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "icons":{
      "opiumware-logo": {
        "description": "Opiumware logo",
        "default": {
          "fontPath": "opiumware.woff",
          "fontCharacter": "\\E001"
        }
      }
    },
    "commands": [
      {
        "command": "opiumware.execute",
        "title": "Execute LuaU Script",
        "icon": "$(opiumware-logo)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "opiumware.execute",
          "group": "navigation",
          "when": "resourceExtname == .lua || resourceExtname == .luau"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
